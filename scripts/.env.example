# Garmin Connect credentials
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=yourpassword
# Token cache dir — shared between garmin_fetch.py and garmin_push_workout.py
# Prevents 429 rate limits from repeated logins. Must be an absolute path.
GARMINTOKENS=/Users/you/.garth

# Supabase — use service_role key (full DB access for n8n/scripts)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase anon key (for read-only queries if needed)
# SUPABASE_ANON_KEY=your-anon-key
